# ============================================================
# FILL THESE IN BEFORE RUNNING ANY DEPLOY SCRIPTS
# ============================================================

# AWS region
AWS_REGION=us-east-1

# A short identifier used to name all resources (no spaces)
APP_NAME=notes-app

# EC2
EC2_INSTANCE_TYPE=t3.micro
EC2_KEY_NAME=notes-app
EC2_KEY_PATH=~/.ssh/notes-app.pem

# RDS PostgreSQL
DB_INSTANCE_ID=notes-db
DB_NAME=notesdb
DB_USER=notesadmin
DB_PASSWORD=agcb1234

# S3 bucket name (must be globally unique)
S3_BUCKET=notes-app-frontend-886418435218

# Domain / CloudFront
DB_HOST=notes-db.c4za6mk4841g.us-east-1.rds.amazonaws.com
# After running 01-infra.sh, fill in the CloudFront domain that gets printed
CLOUDFRONT_DOMAIN=daod9jxngemwy.cloudfront.net

# After running 01-infra.sh, fill in the EC2 public IP/DNS that gets printed
EC2_PUBLIC_IP=32.192.233.241

# JWT signing secret — use a long random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-string-in-production
